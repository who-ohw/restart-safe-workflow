{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/restart-safe-workflow/taskspec-v1.schema.json",
  "title": "Restart Safe Workflow Task Plan v1",
  "type": "object",
  "required": ["taskPlanVersion", "taskId", "actions"],
  "properties": {
    "taskPlanVersion": { "type": "string", "const": "v1" },
    "taskId": { "type": "string", "minLength": 3 },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["actionId", "type"],
        "properties": {
          "actionId": { "type": "string", "minLength": 2 },
          "type": { "type": "string", "enum": ["notify", "query_time", "command", "script", "tool_call"] },
          "deps": { "type": "array", "items": { "type": "string" } },
          "params": { "type": "object" },
          "retryPolicy": {
            "type": "object",
            "properties": {
              "maxRetries": { "type": "integer", "minimum": 0 },
              "backoffSec": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": true
          },
          "timeoutSec": { "type": "integer", "minimum": 1 },
          "onFailure": { "type": "string", "enum": ["stop", "continue", "escalate"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
